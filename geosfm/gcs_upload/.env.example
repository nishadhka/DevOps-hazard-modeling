# Prefect Cloud Configuration
PREFECT_API_KEY=pnu_your_prefect_api_key_here
PREFECT_ACCOUNT_ID=12345678-1234-1234-1234-123456789012
PREFECT_WORKSPACE_ID=87654321-4321-4321-4321-210987654321
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/${PREFECT_ACCOUNT_ID}/workspaces/${PREFECT_WORKSPACE_ID}

# FTP/SFTP Configuration
FTP_HOST=your.ftp.server.com
FTP_USERNAME=your_username
FTP_PASSWORD=your_password
FTP_PORT=21  # Use 22 for SFTP
USE_SFTP=false  # Set to true for SFTP
FTP_REMOTE_PATH=/output

# Google Cloud Storage Configuration
GCS_BUCKET=your-gcs-bucketb
GCP_PROJECT=your-project-id
GCS_PREFIX=ftp-sync
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Sync Configuration
FILE_PATTERN=*.csv  # File pattern to sync
SYNC_DAYS=7  # Only sync files modified in last N days